{
    "path": "cz-conventional-changelog",
    "types": {
        "breaking": {
            "title": "🚨 Breaking Changes",
            "description": "A breaking change"
        },
        "feat": {
            "title": "✨ Features",
            "description": "A new feature"
        },
        "security": {
            "title": "🔒 Security",
            "description": "A security fix"
        },
        "improvement": {
            "title": "🛠 Improvements",
            "description": "General improvements to the codebase"
        },
        "perf": {
            "title": "⚡️ Performance",
            "description": "A code change that improves performance"
        },
        "fix": {
            "title": "🐛 Bug Fixes",
            "description": "A bug fix"
        },
        "docs": {
            "title": "📚 Documentation",
            "description": "Documentation only changes"
        },
        "chore": {
            "title": "🏗 Chore",
            "description": "Other changes that don't modify src or test files"
        },
        "refactor": {
            "title": "♻️ Refactoring",
            "description": "A code change that neither fixes a bug nor adds a feature"
        },
        "test": {
            "title": "🤖 Tests",
            "description": "Adding missing tests or correcting existing tests"
        },
        "style": {
            "title": "🎨 Style",
            "description": "Changes that do not affect the meaning of the code (white-space, formatting, etc)"
        },
        "build": {
            "title": "📦 Build",
            "description": "Changes that affect the build system or external dependencies (example scopes: gulp, broccoli, npm)"
        },
        "ci": {
            "title": "🔄 Continuous Integration",
            "description": "Changes to the CI configuration"
        },
        "wip": {
            "title": "🚧 Wip",
            "description": "Work in progress"
        }
    }
}